# Copy to .env and fill in values.

# --- LiveKit (default browser voice path) ---
# Use the API key + secret from the SAME LiveKit Cloud project as the WebSocket URL (no quotes / stray spaces).
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# --- OpenAI (LLM + summary; STT/TTS fallbacks) ---
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# --- Deepgram (preferred STT) ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2-general

# --- Cartesia (preferred TTS) ---
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_TTS_MODEL=sonic-2

# --- HTTP ---
# CORS: must match the dev URL in the browser exactly (localhost vs 127.0.0.1 differ). Comma-separated for multiple.
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
BACKEND_PUBLIC_URL=http://localhost:8000

# --- Storage ---
DATABASE_PATH=./data/mykare.db

LOG_LEVEL=INFO
